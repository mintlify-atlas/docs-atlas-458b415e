{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Markdoc",
  "theme": "willow",
  "colors": {
    "primary": "#e2d393",
    "light": "#646467",
    "dark": "#212124"
  },
  "favicon": "https://media.brand.dev/86ec7e99-1855-4898-a254-709bf30c82a7.png",
  "logo": {
    "light": "https://media.brand.dev/a6427647-fe94-4206-bb4f-2d062610d0a8.svg",
    "dark": "https://media.brand.dev/a6427647-fe94-4206-bb4f-2d062610d0a8.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/markdoc/markdoc"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/markdoc/markdoc"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/overview",
              "concepts/syntax",
              "concepts/schema",
              "concepts/nodes",
              "concepts/tags"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/custom-tags",
              "guides/custom-nodes",
              "guides/custom-functions",
              "guides/renderers",
              "guides/validation",
              "guides/react-integration"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "advanced/typescript",
              "advanced/error-handling",
              "advanced/performance"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Core API",
            "pages": [
              "api/parse",
              "api/transform",
              "api/validate",
              "api/render"
            ]
          },
          {
            "group": "Built-in Tags",
            "pages": [
              "api/tags/conditional",
              "api/tags/partial",
              "api/tags/slot",
              "api/tags/table"
            ]
          },
          {
            "group": "Nodes",
            "pages": [
              "api/nodes/overview",
              "api/nodes/markdown-nodes",
              "api/nodes/custom-nodes"
            ]
          },
          {
            "group": "Functions",
            "pages": [
              "api/functions/overview",
              "api/functions/built-in"
            ]
          },
          {
            "group": "Renderers",
            "pages": [
              "api/renderers/react",
              "api/renderers/html"
            ]
          },
          {
            "group": "Types",
            "pages": [
              "api/types/config",
              "api/types/schema",
              "api/types/node",
              "api/types/tag"
            ]
          }
        ]
      }
    ]
  }
}
